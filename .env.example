# ============================================================================
# FranzPLAY - Variabili d'ambiente (copia in .env e modifica)
# ============================================================================

# --- Credenziali Database MariaDB ---
MYSQL_ROOT_PASSWORD=la_tua_password_root
MYSQL_DATABASE=FranzPLAY_DBMS
MYSQL_USER=tuo_username
MYSQL_PASSWORD=tua_password

# --- Cache Redis ---
# Lascia vuoto per disabilitare l'auth (Redis comunque NON è esposto fuori dalla rete docker).
# Imposta una password robusta in produzione.
REDIS_PASSWORD=

# --- Percorsi ---
# Cartella reale del server dove sono presenti i video.
PERCORSO_VIDEO="./testVideo"

# --- Tuning Python workers (opzionale) ---
# WATCHER_POLL_TIMEOUT=5
# WORKER_POLL_INTERVAL=10
# WORKER_BACKOFF_MAX=120
# FFMPEG_PRESET=ultrafast      # ultrafast/superfast/veryfast/fast/medium
# FFMPEG_COVER_TIMEOUT=20
# FFMPEG_PREVIEW_TIMEOUT=60
