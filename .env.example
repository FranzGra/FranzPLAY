# ============================================================================
# FranzPLAY - Variabili d'ambiente (copia in .env e modifica)
# ============================================================================

# --- Credenziali Database MariaDB ---
MYSQL_ROOT_PASSWORD=la_tua_password_root
MYSQL_DATABASE=FranzPLAY_DBMS
MYSQL_USER=tuo_username
MYSQL_PASSWORD=tua_password

# --- Cache Redis ---
# Lascia vuoto per disabilitare l'auth (Redis comunque NON è esposto fuori dalla rete docker).
# Imposta una password robusta in produzione.
REDIS_PASSWORD=

# --- Percorsi ---
# Cartella reale del server dove sono presenti i video.
PERCORSO_VIDEO="./testVideo"

# --- Deploy / Naming container (opzionale) ---
# Prefisso applicato al nome di TUTTI i container (default vuoto = nomi standard).
# Utile per far convivere più stack sulla stessa macchina. Es. ZimaBlade: FS_
# CONTAINER_PREFIX=
# Porte pubblicate da nginx (default 80/443). Cambiale se le standard sono occupate.
# Es. ZimaBlade dietro reverse proxy: NGINX_HTTP_PORT=8090
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443
# Immagine PhpMyAdmin: su host x86 usa la multi-arch ufficiale.
# Default (Raspberry/ARM64): arm64v8/phpmyadmin:latest
# PHPMYADMIN_IMAGE=phpmyadmin/phpmyadmin:latest

# --- Tuning Python workers (opzionale) ---
# WATCHER_POLL_TIMEOUT=5
# WORKER_POLL_INTERVAL=10
# WORKER_BACKOFF_MAX=15           # tetto attesa idle worker meta/assets (reattività)
# SUBTITLES_POLL_INTERVAL=10
# SUBTITLES_BACKOFF_MAX=10        # worker sottotitoli on-demand: poll frequente
# FFMPEG_PRESET=ultrafast      # ultrafast/superfast/veryfast/fast/medium
# FFMPEG_COVER_TIMEOUT=20
# FFMPEG_PREVIEW_TIMEOUT=60

# --- Tuning Worker Optimizer (remux fMP4 faststart) ---
# Intervallo base di polling DB; backoff esponenziale fino a OPTIMIZER_BACKOFF_MAX.
# OPTIMIZER_POLL_INTERVAL=30
# OPTIMIZER_BACKOFF_MAX=300
# Ore di grazia prima di cancellare l'originale dopo il remux (failsafe).
# OPTIMIZER_CLEANUP_HOURS=24
# Cap timeout ffmpeg per remux (1800s = 30min, copre 8GB 4K HEVC su SD card).
# OPTIMIZER_REMUX_TIMEOUT=1800
# OPTIMIZER_AUDIO_TIMEOUT=600
